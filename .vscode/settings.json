{
  "editor.formatOnSave": true,
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[html]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "djlint.showInstallError": false,
  "cSpell.words": [
    "Acrisure",
    "Andel",
    "arcgis",
    "GBFS",
    "GTFS",
    "labelledby",
    "linecap",
    "linejoin",
    "micromobility",
    "nodemon",
    "nowrap",
    "onclick",
    "pycache",
    "rideshare",
    "stylesheet",
    "unmetered"
  ]
}
